# Copy this file to .env and fill in your values

# Moomoo OpenD connection (running on this same PC)
MOOMOO_OPEND_HOST=127.0.0.1
MOOMOO_OPEND_PORT=11111

# HTTP server port (Cloudflare tunnel should point here)
SCANNER_PROXY_PORT=3001

# Shared secret — set the same value in Hostinger env as SCANNER_PROXY_SECRET
SCANNER_PROXY_SECRET=change-me-to-a-random-secret

# Moomoo account (needed for Account Funds)
MOOMOO_ACCOUNT_ID=
MOOMOO_TRADE_PWD_MD5=
MOOMOO_SECURITY_FIRM=3
MOOMOO_TRD_MARKET=2
MOOMOO_CURRENCY=2

# Endpoints exposed:
#   GET  /health   — liveness check
#   POST /scan     — option scanner (tickers + params → filtered PUT options)
#   POST /quotes   — live price refresh (positions → current option prices + IV + delta)
