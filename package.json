{
  "name": "strikecapital",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "server/src/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "cross-env NODE_ENV=development nodemon server/src/index.js",
    "server:prod": "cross-env NODE_ENV=production node server/src/index.js",
    "client": "cd client && npm start",
    "client:dev": "cd client && npm run dev",
    "client:build": "cd client && npm install --force && npm run build",
    "client:build:dev": "cd client && npm install --force && npm run build",
    "client:build:prod": "cd client && npm install --force && npm run build",
    "build": "cd client && npm install --force && npm run build",
    "build:dev": "cd client && npm install --force && npm run build",
    "build:prod": "cd client && npm install --force && npm run build",
    "build-and-serve": "npm run build:prod && npm run server:prod",
    "start": "cross-env NODE_ENV=production node server/src/index.js",
    "start:prod": "cross-env NODE_ENV=production node server/src/index.js",
    "install-all": "npm install && cd client && npm install",
    "db:migrate": "knex migrate:latest --knexfile server/knexfile.js",
    "db:migrate:make": "knex migrate:make --knexfile server/knexfile.js",
    "db:rollback": "knex migrate:rollback --knexfile server/knexfile.js",
    "db:seed": "knex seed:run --knexfile server/knexfile.js",
    "db:seed:make": "knex seed:make --knexfile server/knexfile.js",
    "scanner-proxy": "node server/scanner-proxy.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "mime-types": "^2.1.35",
    "moomoo-api": "^10.0.6008",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.12.0",
    "nodemailer": "^6.9.8",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdfkit": "^0.17.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "eslint": "^8.56.0",
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": "18.x"
  }
}
